# Bcrypt hash of the 6-digit passcode. Generate with: python scripts/hash_passcode.py
# IMPORTANT: when using docker-compose's env_file:, escape every $ as $$
# (e.g. $2b$12$abc... becomes $$2b$$12$$abc...).
ZOEY_PASSCODE_HASH=

# Random secret for signing session cookies. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Optional overrides
TZ=Europe/Vienna
COMPARISON_THRESHOLD_PCT=15
