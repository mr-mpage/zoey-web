# ─── Required ─────────────────────────────────────────────────────────────
# The app refuses to start until both of these are set.

# Bcrypt hash of the shared passcode. Generate with:
#     python scripts/hash_passcode.py <your-pin>
# IMPORTANT: when using docker-compose's env_file:, escape every $ as $$
#   e.g.  $2b$12$abc...   →   $$2b$$12$$abc...
ZOEY_PASSCODE_HASH=

# Random secret for signing session cookies. A blank value means anyone can
# forge cookies — generate a strong one:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# ─── Optional overrides ───────────────────────────────────────────────────

TZ=Europe/Vienna
COMPARISON_THRESHOLD_PCT=15

# CIDRs / IPs allowed to set X-Forwarded-For. The auth layer only honours XFF
# from these peers; otherwise rate-limit attribution falls back to the direct
# socket address. Default covers loopback (the typical reverse-proxy setup).
TRUSTED_PROXIES=127.0.0.1,::1

# Set to false ONLY for local dev over plain http. Production must always
# run behind TLS with this true (or unset). Safari and older Firefox drop
# Secure cookies on http, which makes login appear to hang on "checking…"
# when you're testing without a TLS proxy in front.
COOKIE_SECURE=true

# ─── Web Push (optional) ─────────────────────────────────────────────────
# Generate a VAPID keypair and an admin contact email. Leave blank to disable
# push reminders.
#     pip install pywebpush  # (already a backend dep)
#     python -c "from py_vapid import Vapid01 as V; v = V(); v.generate_keys(); print('VAPID_PUBLIC_KEY=' + v.public_pem().decode().strip()); print('VAPID_PRIVATE_KEY=' + v.private_pem().decode().strip())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact email surfaced to push providers in the JWT 'sub' claim. Use an
# address you own; providers may email it on delivery issues.
VAPID_CONTACT_EMAIL=

# ─── Owlet Dream Sock integration (optional) ─────────────────────────────
# Configure email + password + region in the running app via
# Settings → Owlet vitals. The password is encrypted at rest in the
# SQLite DB (Fernet keyed off SESSION_SECRET); rotating SESSION_SECRET
# requires re-entering the Owlet password.
#
# The three ZOEY_OWLET_* vars below are still read at first boot and
# migrated into the DB so existing deployments keep working — once the
# DB has values, these env vars are ignored and can be removed.
ZOEY_OWLET_EMAIL=
ZOEY_OWLET_PASSWORD=
ZOEY_OWLET_REGION=europe
OWLET_POLL_INTERVAL_S=120
VITALS_RAW_RETAIN_DAYS=14
